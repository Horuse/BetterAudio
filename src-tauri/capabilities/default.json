{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:window:allow-start-dragging",
		"opener:default",
		"store:default",
		"dialog:default",
		"dialog:allow-save",
		"updater:default",
		"process:default",
		"process:allow-restart",
		"os:default",
		"os:allow-platform",
		"os:allow-version",
		"os:allow-arch",
		"os:allow-hostname"
	]
}
